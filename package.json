{
  "name": "raycast-translator",
  "title": "Translator",
  "description": "翻译工具 - 支持中英文自动互翻",
  "icon": "command-icon.png",
  "author": "local",
  "license": "MIT",
  "commands": [
    {
      "name": "translate",
      "title": "Translate",
      "subtitle": "Translate",
      "description": "查询单词或句子的翻译",
      "mode": "view"
    },
    {
      "name": "translate-selection",
      "title": "Translate Selection",
      "subtitle": "Translate",
      "description": "翻译选中的文字",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "appKey",
      "type": "textfield",
      "required": true,
      "title": "App Key",
      "description": "翻译服务应用ID",
      "placeholder": "请输入 App Key"
    },
    {
      "name": "appSecret",
      "type": "password",
      "required": true,
      "title": "App Secret",
      "description": "翻译服务应用密钥",
      "placeholder": "请输入 App Secret"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.64.0",
    "@raycast/utils": "^1.10.0",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray fix-lint",
    "lint": "ray lint"
  }
}